#!/bin/bash
SSCREEN_COMPLETION='_sscreen_hosts() {
    grep -i "^Host " "$HOME/.ssh/config" | awk '\''{print $2}'\'' | grep -v '\''*'\''
}
_sscreen() {
    local cur prev
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"
    local actions="connect list run hosts"
    if [[ $COMP_CWORD -eq 1 ]]; then
        COMPREPLY=($(compgen -W "$(_sscreen_hosts) ${actions}" -- "${cur}"))
        return 0
    fi
    if [[ $COMP_CWORD -eq 2 ]]; then
        case "${prev}" in
            connect|c|list|l|run|r)
                COMPREPLY=($(compgen -W "$(_sscreen_hosts)" -- "${cur}"))
                return 0
                ;;
        esac
    fi
}
complete -F _sscreen sscreen
'
SSH_CONFIG="$HOME/.ssh/config"
load_hosts() {
    grep -i "^Host " "$SSH_CONFIG" | awk '{print $2}' | grep -v '*'
}
get_host() {
    local host="$1"
    if [[ -f "$SSH_CONFIG" ]]; then
        grep -qi "^Host $host$" "$SSH_CONFIG" && echo "$host"
    fi
}
install_sscreen() {
    mkdir -p ~/.local/bin
    if ! grep -q '\.local/bin' ~/.bashrc 2>/dev/null; then
        echo 'export PATH="$HOME/.local/bin:$PATH"' >> ~/.bashrc
    fi
    ln -sf "$(pwd)/sscreen" ~/.local/bin/sscreen
    mkdir -p ~/.local/share/bash-completion/completions
    echo "$SSCREEN_COMPLETION" > ~/.local/share/bash-completion/completions/sscreen
    echo "Installed! Run 'source ~/.bashrc' to enable tab completion."
}
ACTION=""
HOST=""
SCREEN_NAME=""
if [[ $# -eq 0 ]]; then
    echo "Usage: sscreen <host> [screen-name|attach|run|list|kill]"
    echo "       sscreen <host> <name>       # create named screen and attach"
    echo "       sscreen <host> attach <screen>  # attach to existing screen"
    echo "       sscreen <host> run <name> <cmd> # run command in named screen"
    echo "       sscreen <host> list         # list screens on host"
    echo "       sscreen <host> kill <screen>   # kill a screen"
    echo "       sscreen list                # list screens on all hosts"
    echo "       sscreen hosts               # show SSH config hosts"
    echo "       sscreen --install           # install sscreen and completion"
    exit 1
fi
if [[ $# -eq 1 ]]; then
    case "$1" in
        --install)
            install_sscreen
            exit 0
            ;;
        hosts)
            load_hosts
            exit 0
            ;;
        list)
            hosts=$(load_hosts)
            total=$(echo "$hosts" | wc -l)
            count=0
            echo "Checking screens on $total hosts..."
            for h in $hosts; do
                count=$((count + 1))
                echo -n "[$count/$total] $h... "
                output=$(timeout 8 ssh -o BatchMode=yes -o ConnectTimeout=3 -o StrictHostKeyChecking=no -o LogLevel=ERROR -o ConnectionAttempts=1 -t "$h" 'screen -ls' 2>&1)
                ret=$?
                if [[ $ret -eq 0 ]] || [[ $ret -eq 1 ]] || [[ $ret -eq 124 ]]; then
                    clean_output=$(echo "$output" | tr -d '\r' | grep -v "Pseudo-terminal will not be allocated")
                    if echo "$clean_output" | grep -q "screens on"; then
                        echo "FOUND"
                        echo "=== $h ==="
                        echo "$clean_output"
                    else
                        echo "ok"
                    fi
                else
                    echo "fail"
                fi
            done
            exit 0
            ;;
        *)
            HOST="$1"
            ;;
    esac
else
    ACTION="$2"
    HOST="$1"
    SCREEN_NAME="$3"
fi
if ! get_host "$HOST" >/dev/null; then
    echo "Error: Host '$HOST' not found in $SSH_CONFIG"
    exit 1
fi
echo "Connecting to $HOST..."
case "$ACTION" in
    attach|a)
        if [[ -z "$SCREEN_NAME" ]]; then
            echo "Usage: sscreen <host> attach <screen-name|pid>"
            exit 1
        fi
        ssh -t "$HOST" "screen -dr $SCREEN_NAME"
        ;;
    run|r)
        if [[ -z "$SCREEN_NAME" ]]; then
            echo "Usage: sscreen <host> run <name> <command>"
            exit 1
        fi
        shift 2
        ssh -t "$HOST" "screen -S $SCREEN_NAME $*"
        ;;
    list|l)
        ssh -t "$HOST" 'screen -ls'
        ;;
    kill|k)
        if [[ -z "$SCREEN_NAME" ]]; then
            echo "Usage: sscreen <host> kill <screen-name|pid>"
            exit 1
        fi
        ssh -t "$HOST" "screen -S $SCREEN_NAME -X quit"
        ;;
    hosts)
        load_hosts
        ;;
    *)
        if [[ -n "$ACTION" ]]; then
            ssh -t "$HOST" "screen -S $ACTION -xRR"
        else
            ssh -t "$HOST" 'screen -Rd'
        fi
        ;;
esac
